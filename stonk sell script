local ReplicatedStorage = game:GetService("ReplicatedStorage")

print("========================================")
print("🚀 BẮT ĐẦU TEST LỆNH BÁN (1 LẦN DUY NHẤT)")

-- Lần theo đường dẫn RemoteFunction BÁN mày vừa bắt được
local sellRemote = ReplicatedStorage:WaitForChild("Packages")
    :WaitForChild("_Index")
    :WaitForChild("sleitnick_knit@1.7.0")
    :WaitForChild("knit")
    :WaitForChild("Services")
    :WaitForChild("Stocks")
    :WaitForChild("RF")
    :WaitForChild("MarketSellPoints") -- <<< Đổi thành MarketSellPoints

-- Tham số bê y nguyên từ log của mày
local targetID = 4395734339 -- Mã ID cổ phiếu/thằng mua
local quantity = 1          -- Bán 1 cổ phiếu

-- Hàm test gửi lệnh
local function testSingleSell()
    print("📉 Đang gửi lệnh: BÁN Stonk của ID [" .. tostring(targetID) .. "], SL: " .. tostring(quantity))
    
    -- Dùng pcall để lỡ server nó chặn lệnh thì đéo bị văng game
    local success, response = pcall(function()
        return sellRemote:InvokeServer(targetID, quantity)
    end)

    if success then
        print("✅ GỬI LỆNH TRÓT LỌT! Server trả lời:")
        print(response) -- Xem phản hồi từ server (ví dụ: true, "Sold", v.v.)
    else
        print("❌ LỆNH BỊ CHẶN HOẶC LỖI! Nguyên nhân:")
        print(response)
    end
end

-- Bóp cò xả hàng ngay lập tức khi load script
testSingleSell()
print("========================================")
