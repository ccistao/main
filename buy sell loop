-- ================= LOGIC HOẠT ĐỘNG =================
local isLoopingBuy = false
local isLoopingSell = false
local LOOP_SPEED = 0.1 -- Độ trễ giữa mỗi lần spam (tránh crash server/văng game)

local function executeBuy()
    local id = tonumber(IDInput.Text)
    local qty = tonumber(BuyQty.Text)
    if id and qty and buyRemote then
        pcall(function() buyRemote:InvokeServer(id, qty) end)
    end
end

local function executeSell()
    local id = tonumber(IDInput.Text)
    local qty = tonumber(SellQty.Text)
    if id and qty and sellRemote then
        pcall(function() sellRemote:InvokeServer(id, qty) end)
    end
end

-- Bấm 1 lần
BtnBuyOnce.Activated:Connect(executeBuy)
BtnSellOnce.Activated:Connect(executeSell)

-- Hàm Bật/Tắt Loop Buy
local function toggleLoopBuy()
    isLoopingBuy = not isLoopingBuy
    if isLoopingBuy then
        BtnLoopBuy.BackgroundColor3 = Color3.fromRGB(50, 200, 50) -- Xanh
        task.spawn(function()
            while isLoopingBuy do
                executeBuy()
                task.wait(LOOP_SPEED)
            end
        end)
    else
        BtnLoopBuy.BackgroundColor3 = Color3.fromRGB(200, 50, 50) -- Đỏ
    end
end
BtnLoopBuy.Activated:Connect(toggleLoopBuy)

-- Hàm Bật/Tắt Loop Sell
local function toggleLoopSell()
    isLoopingSell = not isLoopingSell
    if isLoopingSell then
        BtnLoopSell.BackgroundColor3 = Color3.fromRGB(50, 200, 50) -- Xanh
        task.spawn(function()
            while isLoopingSell do
                executeSell()
                task.wait(LOOP_SPEED)
            end
        end)
    else
        BtnLoopSell.BackgroundColor3 = Color3.fromRGB(200, 50, 50) -- Đỏ
    end
end
BtnLoopSell.Activated:Connect(toggleLoopSell)

-- ================= BẮT KEYBIND (Q và E) =================
UIS.InputBegan:Connect(function(input, gameProcessed)
    -- Nếu đang chat hoặc gõ chữ trong TextBox thì bỏ qua
    if gameProcessed then return end 
    
    if input.KeyCode == Enum.KeyCode.Q then
        toggleLoopBuy()
    elseif input.KeyCode == Enum.KeyCode.E then
        toggleLoopSell()
    end
end)
